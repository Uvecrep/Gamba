[gd_resource type="Resource" script_class="Lootbox" format=3]

[ext_resource type="Script" path="res://entities/lootbox/lootbox.gd" id="1_lootbox"]
[ext_resource type="Script" path="res://entities/lootbox/loot_entry.gd" id="2_entry"]
[ext_resource type="Script" path="res://entities/lootbox/lootbox_outcome_spawn_summon.gd" id="3_spawn_outcome"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/greed/mimic.png" id="4_mimic_texture"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/greed/coin_sprite.png" id="5_coin_sprite_texture"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/greed/prospector.png" id="6_prospector_texture"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/greed/golden_gunner.png" id="7_golden_gunner_texture"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/greed/tax_collector.png" id="8_tax_collector_texture"]

[sub_resource type="Resource" id="Outcome_Greed_Mimic"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("4_mimic_texture")
summon_identity = &"mimic"

[sub_resource type="Resource" id="Entry_Greed_Mimic"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Greed_Mimic")
weight = 1.5
name = "Mimic"
rarity_override = 0

[sub_resource type="Resource" id="Outcome_Greed_CoinSprite"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("5_coin_sprite_texture")
summon_identity = &"coin_sprite"

[sub_resource type="Resource" id="Entry_Greed_CoinSprite"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Greed_CoinSprite")
weight = 1.5
name = "Coin Sprite"
rarity_override = 0

[sub_resource type="Resource" id="Outcome_Greed_Prospector"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("6_prospector_texture")
summon_identity = &"prospector"

[sub_resource type="Resource" id="Entry_Greed_Prospector"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Greed_Prospector")
weight = 1.0
name = "Prospector Golem"
rarity_override = 1

[sub_resource type="Resource" id="Outcome_Greed_GoldenGunner"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("7_golden_gunner_texture")
summon_identity = &"golden_gunner"

[sub_resource type="Resource" id="Entry_Greed_GoldenGunner"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Greed_GoldenGunner")
weight = 1.0
name = "Golden Gunner"
rarity_override = 1

[sub_resource type="Resource" id="Outcome_Greed_TaxCollector"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("8_tax_collector_texture")
summon_identity = &"tax_collector"

[sub_resource type="Resource" id="Entry_Greed_TaxCollector"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Greed_TaxCollector")
weight = 0.75
name = "Tax Collector"
rarity_override = 2

[resource]
script = ExtResource("1_lootbox")
id = &"greed"
name = "Greed Box"
color = "Yellow"
description = "A risky investment box with wealth-scaling summons and economy effects."
lootTable = Array[ExtResource("2_entry")]([SubResource("Entry_Greed_Mimic"), SubResource("Entry_Greed_CoinSprite"), SubResource("Entry_Greed_Prospector"), SubResource("Entry_Greed_GoldenGunner"), SubResource("Entry_Greed_TaxCollector")])
