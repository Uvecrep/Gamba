[gd_resource type="Resource" script_class="Lootbox" format=3]

[ext_resource type="Script" path="res://entities/lootbox/lootbox.gd" id="1_lootbox"]
[ext_resource type="Script" path="res://entities/lootbox/loot_entry.gd" id="2_entry"]
[ext_resource type="Script" path="res://entities/lootbox/lootbox_outcome_spawn_summon.gd" id="3_spawn_outcome"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/spirit/soul_lantern.png" id="4_soul_lantern_texture"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/spirit/banshee.png" id="5_banshee_texture"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/spirit/grave_hound.png" id="6_grave_hound_texture"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/spirit/hex_doll.png" id="7_hex_doll_texture"]
[ext_resource type="Texture2D" path="res://assets/characters/summons/spirit/possessor.png" id="8_possessor_texture"]

[sub_resource type="Resource" id="Outcome_Spirit_SoulLantern"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("4_soul_lantern_texture")
summon_identity = &"soul_lantern"

[sub_resource type="Resource" id="Entry_Spirit_SoulLantern"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Spirit_SoulLantern")
weight = 1.0
name = "Soul Lantern"

[sub_resource type="Resource" id="Outcome_Spirit_Banshee"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("5_banshee_texture")
summon_identity = &"banshee"

[sub_resource type="Resource" id="Entry_Spirit_Banshee"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Spirit_Banshee")
weight = 1.0
name = "Banshee"

[sub_resource type="Resource" id="Outcome_Spirit_GraveHound"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("6_grave_hound_texture")
summon_identity = &"grave_hound"

[sub_resource type="Resource" id="Entry_Spirit_GraveHound"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Spirit_GraveHound")
weight = 1.0
name = "Grave Hound"

[sub_resource type="Resource" id="Outcome_Spirit_HexDoll"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("7_hex_doll_texture")
summon_identity = &"hex_doll"

[sub_resource type="Resource" id="Entry_Spirit_HexDoll"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Spirit_HexDoll")
weight = 1.0
name = "Hex Doll"

[sub_resource type="Resource" id="Outcome_Spirit_Possessor"]
script = ExtResource("3_spawn_outcome")
summon_texture_override = ExtResource("8_possessor_texture")
summon_identity = &"possessor"

[sub_resource type="Resource" id="Entry_Spirit_Possessor"]
script = ExtResource("2_entry")
outcome = SubResource("Outcome_Spirit_Possessor")
weight = 1.0
name = "Possessor"

[resource]
script = ExtResource("1_lootbox")
id = &"spirit"
name = "Spirit Box"
color = "Purple"
description = "Bound to souls and curses. Contains five utility-focused spirit summons."
lootTable = Array[ExtResource("2_entry")]([SubResource("Entry_Spirit_SoulLantern"), SubResource("Entry_Spirit_Banshee"), SubResource("Entry_Spirit_GraveHound"), SubResource("Entry_Spirit_HexDoll"), SubResource("Entry_Spirit_Possessor")])
